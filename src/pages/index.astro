---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import Hero from "@/components/Hero.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { compareByDate, compareByOrder, formatDate, withBase } from "@/lib/utils";

const allProjects = (await getCollection("projects")).sort(compareByOrder);
const featuredProjects = allProjects.filter((entry) => entry.data.featured);
const standardProjects = allProjects.filter((entry) => !entry.data.featured);
const latestPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(compareByDate).slice(0, 2);
---

<BaseLayout>
  <Hero />

  <section id="projects" class="py-12 sm:py-18">
    <Container>
      <SectionHeading
        eyebrow="Projects"
        title="Selected work across applied AI, data operations, and connected systems."
      />

      <div class="grid gap-6 lg:grid-cols-2">
        {featuredProjects.map((entry) => <ProjectCard entry={entry} featured />)}
      </div>

      {standardProjects.length > 0 && (
        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          {standardProjects.map((entry) => <ProjectCard entry={entry} />)}
        </div>
      )}

      <div class="mt-10">
        <LinkButton href="/projects/" variant="secondary">Browse all projects</LinkButton>
      </div>
    </Container>
  </section>

  {latestPosts.length > 0 && (
    <section id="blog" class="py-12 sm:py-18">
      <Container>
        <SectionHeading
          eyebrow="Blog"
          title="Writing on applied AI, data systems, and startup execution."
          description="A small editorial layer for ideas worth expanding beyond a project card."
        />

        <div class="grid gap-6 lg:grid-cols-2">
          {
            latestPosts.map((post) => (
              <article class="surface-card p-6 sm:p-7">
                <p class="text-sm font-medium text-[color:var(--color-muted)]">{formatDate(post.data.publishDate)}</p>
                <h2 class="mt-4 max-w-3xl text-2xl leading-tight font-semibold sm:text-3xl">
                  <a href={withBase(`/notes/${post.id}/`)} class="hover:text-[color:var(--color-accent-strong)]">
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-4 max-w-3xl text-base leading-8">{post.data.description}</p>
                <div class="mt-6">
                  <LinkButton href={`/notes/${post.id}/`} variant="secondary">Read post</LinkButton>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-10">
          <LinkButton href="/notes/" variant="ghost">Visit blog</LinkButton>
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
