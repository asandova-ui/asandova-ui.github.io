---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import ExperienceItem from "@/components/ExperienceItem.astro";
import Hero from "@/components/Hero.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SkillGroup from "@/components/SkillGroup.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contactLinks, experience, siteConfig, skillGroups } from "@/lib/site";
import { compareByDate, compareByOrder, formatDate, withBase } from "@/lib/utils";

const allProjects = (await getCollection("projects")).sort(compareByOrder);
const featuredProjects = allProjects.filter((entry) => entry.data.featured);
const standardProjects = allProjects.filter((entry) => !entry.data.featured);
const latestPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(compareByDate).slice(0, 2);
---

<BaseLayout>
  <Hero />

  <section id="about" class="py-14 sm:py-20">
    <Container class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="space-y-5">
        <span class="eyebrow">About</span>
        <h2 class="text-3xl leading-tight font-semibold sm:text-4xl">
          Engineering depth, delivery restraint, and systems-level clarity.
        </h2>
        <p class="section-copy">{siteConfig.about}</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <article class="surface-card p-6 sm:p-7">
          <h3 class="text-xl font-semibold">Current focus</h3>
          <ul class="mt-5 space-y-3">
            {
              siteConfig.currentFocus.map((item) => (
                <li class="flex gap-3 text-sm leading-7 sm:text-base">
                  <span aria-hidden="true" class="mt-3 size-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="surface-card p-6 sm:p-7">
          <h3 class="text-xl font-semibold">Strengths</h3>
          <ul class="mt-5 space-y-3">
            {
              siteConfig.strengths.map((item) => (
                <li class="flex gap-3 text-sm leading-7 sm:text-base">
                  <span aria-hidden="true" class="mt-3 size-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>
      </div>
    </Container>
  </section>

  <section id="projects" class="py-14 sm:py-20">
    <Container>
      <SectionHeading
        eyebrow="Projects"
        title="Selected work across telecom systems, applied AI, and infrastructure-heavy delivery."
        description="Project content lives in MDX so you can add new case studies without editing the page structure. Featured work is highlighted here; the rest is easy to expand."
      />

      <div class="grid gap-6 lg:grid-cols-2">
        {featuredProjects.map((entry) => <ProjectCard entry={entry} featured />)}
      </div>

      {standardProjects.length > 0 && (
        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          {standardProjects.map((entry) => <ProjectCard entry={entry} />)}
        </div>
      )}

      <div class="mt-10">
        <LinkButton href="/projects/" variant="secondary">Browse all projects</LinkButton>
      </div>
    </Container>
  </section>

  <section id="experience" class="py-14 sm:py-20">
    <Container>
      <SectionHeading
        eyebrow="Experience"
        title="A minimal timeline that keeps the focus on impact rather than job-description filler."
        description="The starter entries below are intentionally marked as placeholders. Replace them in one file to update both this section and the CV page."
      />

      <div class="relative space-y-6 border-l border-dashed border-[color:var(--color-border)] pl-1">
        {experience.map((item) => <ExperienceItem item={item} />)}
      </div>
    </Container>
  </section>

  <section id="skills" class="py-14 sm:py-20">
    <Container>
      <SectionHeading
        eyebrow="Skills"
        title="Grouped capabilities that read like a technical profile, not a keyword wall."
        description="Adjust the categories to match your actual strengths and the kinds of roles or clients you want to attract."
      />

      <div class="grid gap-6 md:grid-cols-2">
        {skillGroups.map((group) => <SkillGroup group={group} />)}
      </div>
    </Container>
  </section>

  <section id="notes" class="py-14 sm:py-20">
    <Container>
      <SectionHeading
        eyebrow="Writing"
        title="Short notes and technical essays, ready to grow into a proper writing section."
        description="Posts are authored in MDX. Use them for architecture thinking, field notes, or sharp technical opinions."
      />

      <div class="grid gap-6 lg:grid-cols-2">
        {
          latestPosts.map((post) => (
            <article class="surface-card p-6 sm:p-7">
              <p class="text-sm font-medium text-[color:var(--color-muted)]">{formatDate(post.data.publishDate)}</p>
              <h3 class="mt-4 text-2xl leading-tight font-semibold">
                <a href={withBase(`/notes/${post.id}/`)} class="hover:text-[color:var(--color-accent-strong)]">
                  {post.data.title}
                </a>
              </h3>
              <p class="mt-4 text-base leading-8">{post.data.description}</p>
              <div class="mt-6">
                <LinkButton href={`/notes/${post.id}/`} variant="ghost">Read note</LinkButton>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-10">
        <LinkButton href="/notes/" variant="secondary">View all notes</LinkButton>
      </div>
    </Container>
  </section>

  <section id="contact" class="py-14 sm:py-20">
    <Container>
      <div class="surface-card overflow-hidden p-8 sm:p-10 lg:p-12">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
          <div class="space-y-5">
            <span class="eyebrow">Contact</span>
            <h2 class="max-w-3xl text-3xl leading-tight font-semibold sm:text-4xl">
              If the work demands technical seriousness, systems thinking, and clean execution, let&apos;s talk.
            </h2>
            <p class="section-copy">
              The contact details below are centralized, so you can update the footer, hero, and this section from a single file.
            </p>
            <SocialLinks links={siteConfig.socialLinks} />
          </div>

          <div class="flex flex-col gap-3">
            <LinkButton href={contactLinks.email}>Email Alonso</LinkButton>
            <LinkButton href={contactLinks.linkedin} variant="secondary" external>
              LinkedIn
            </LinkButton>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
