---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import Hero from "@/components/Hero.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { compareByDate, compareByOrder, formatDate, withBase } from "@/lib/utils";

const allProjects = (await getCollection("projects")).sort(compareByOrder);
const featuredProjects = allProjects.filter((entry) => entry.data.featured);
const standardProjects = allProjects.filter((entry) => !entry.data.featured);
const latestPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(compareByDate).slice(0, 2);
---

<BaseLayout>
  <Hero />

  <section id="projects" class="pt-2 pb-14 sm:pt-4 sm:pb-16">
    <Container>
      <SectionHeading eyebrow="Projects" />

      <div class="grid gap-0">
        {featuredProjects.map((entry, index) => <ProjectCard entry={entry} featured index={index} />)}
      </div>

      {standardProjects.length > 0 && (
        <div class="grid gap-0">
          {standardProjects.map((entry, index) => <ProjectCard entry={entry} index={featuredProjects.length + index} />)}
        </div>
      )}

      <div class="mt-7">
        <LinkButton href="/projects/" variant="secondary">Browse all projects</LinkButton>
      </div>
    </Container>
  </section>

  {latestPosts.length > 0 && (
    <section id="blog" class="py-12 sm:py-16">
      <Container>
        <SectionHeading eyebrow="Blog" />

        <div class="grid gap-0">
          {
            latestPosts.map((post, index) => (
              <article class="grid gap-3 border-b editorial-rule py-6 transition-colors hover:bg-[rgba(255,252,245,0.28)] sm:grid-cols-[2.8rem_minmax(0,1fr)] sm:py-7 lg:grid-cols-[2.8rem_minmax(0,1fr)_auto] lg:gap-8">
                <span class="font-heading text-[0.78rem] text-[color:var(--color-soft)] sm:pt-1">{String(index + 1).padStart(2, "0")}</span>
                <div class="max-w-3xl">
                  <h2 class="text-[1.22rem] leading-tight font-semibold sm:text-[1.42rem]">
                    <a href={withBase(`/notes/${post.id}/`)} class="hover:text-[color:var(--color-accent-strong)]">
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="mt-2.5 max-w-2xl text-[0.95rem] leading-7 text-[color:var(--color-muted)]">{post.data.description}</p>
                </div>
                <p class="text-[0.82rem] text-[color:var(--color-muted)] sm:col-start-2 lg:col-start-auto lg:text-right">{formatDate(post.data.publishDate)}</p>
                <div class="text-[0.9rem] font-medium sm:col-start-2 lg:col-span-2">
                  <a
                    href={withBase(`/notes/${post.id}/`)}
                    class="inline-flex items-center gap-2 hover:text-[color:var(--color-accent-strong)]"
                  >
                    Read post
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-7">
          <LinkButton href="/notes/" variant="ghost">Visit blog</LinkButton>
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
