---
import { getCollection, render } from "astro:content";
import Container from "@/components/Container.astro";
import LinkButton from "@/components/LinkButton.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: entry.data.title,
  description: entry.data.description
};
const detailStatusToneClasses =
  entry.data.detailStatusTone === "live"
    ? "text-emerald-700"
    : entry.data.detailStatusTone === "neutral"
      ? "text-[color:var(--color-muted)]"
      : "text-[color:var(--color-accent-strong)]";
const detailStatusDotClasses =
  entry.data.detailStatusTone === "live"
    ? "bg-emerald-500"
    : entry.data.detailStatusTone === "neutral"
      ? "bg-[color:var(--color-muted)]/55"
      : "bg-[color:var(--color-accent)]";
---

<BaseLayout title={entry.data.title} description={entry.data.description} structuredData={structuredData}>
  <section class="py-14 sm:py-20">
    <Container class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_22rem]">
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <span class="eyebrow">{entry.data.year}</span>
          {entry.data.detailStatusLabel && (
            <span class:list={[
              "inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.08em]",
              detailStatusToneClasses
            ]}>
              <span aria-hidden="true" class:list={["size-2 rounded-full", detailStatusDotClasses]}></span>
              {entry.data.detailStatusLabel}
            </span>
          )}
        </div>
        <h1 class="mt-5 max-w-4xl text-[2.1rem] leading-tight font-semibold sm:text-[3rem]">{entry.data.title}</h1>
        {entry.data.subtitle && (
          <p class="mt-4 max-w-4xl font-heading text-[1.1rem] leading-8 text-[color:var(--color-fg)]/84 sm:text-[1.28rem]">
            {entry.data.subtitle}
          </p>
        )}
        <p class="mt-5 max-w-3xl text-[1.02rem] leading-8">{entry.data.description}</p>
        {entry.data.pitch && (
          <div class="mt-6 max-w-3xl rounded-2xl border bg-[color:var(--color-surface)] px-6 py-5 text-base leading-8 text-[color:var(--color-fg)]/86">
            {entry.data.pitch}
          </div>
        )}

        <div class="mt-10 rich-content">
          <Content />
        </div>
      </div>

      <aside class="space-y-6">
        {entry.data.detailStatusNote && (
          <div class="surface-card p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Status</p>
            <p class="mt-3 font-heading text-lg leading-tight font-semibold text-[color:var(--color-fg)]">
              {entry.data.detailStatusLabel}
            </p>
            <p class="mt-3 text-sm leading-7">{entry.data.detailStatusNote}</p>
          </div>
        )}

        <div class="surface-card p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Role</p>
          <p class="mt-3 text-sm leading-7">{entry.data.role}</p>
        </div>

        <div class="surface-card p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Outcome</p>
          <p class="mt-3 text-sm leading-7">{entry.data.outcome}</p>
        </div>

        <div class="surface-card p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Stack</p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {entry.data.stack.map((item) => <li class="chip">{item}</li>)}
          </ul>
        </div>

        {entry.data.tags.length > 0 && (
          <div class="surface-card p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Tags</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {entry.data.tags.map((item) => <li class="chip">{item}</li>)}
            </ul>
          </div>
        )}

        {entry.data.links.length > 0 && (
          <div class="surface-card p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--color-muted)]">Links</p>
            <div class="mt-4 flex flex-col gap-3">
              {entry.data.links.map((link) => <LinkButton href={link.href} variant="secondary" external>{link.label}</LinkButton>)}
            </div>
          </div>
        )}
      </aside>
    </Container>
  </section>
</BaseLayout>
