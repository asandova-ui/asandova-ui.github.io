---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { compareByOrder } from "@/lib/utils";

const projects = (await getCollection("projects")).sort(compareByOrder);
const featuredProjects = projects.filter((entry) => entry.data.featured);
const archiveProjects = projects.filter((entry) => !entry.data.featured);
---

<BaseLayout title="Projects" description="Selected projects spanning AI products, AI data platforms, and infrastructure-focused engineering.">
  <section class="py-14 sm:py-20">
    <Container>
      <SectionHeading
        eyebrow="Projects"
        title="Case studies across AI products, AI data platforms, and technical execution."
        description="The structure is designed so you can keep adding work without touching layout code. Featured AI projects appear first, followed by supporting case studies."
      />

      <div class="grid gap-0">
        {featuredProjects.map((entry, index) => <ProjectCard entry={entry} featured index={index} />)}
      </div>

      {archiveProjects.length > 0 && (
        <div class="mt-12 sm:mt-14">
          <h2 class="font-heading text-[1.25rem] font-semibold sm:text-[1.42rem]">Additional work</h2>
          <div class="mt-5 grid gap-0">
            {archiveProjects.map((entry, index) => <ProjectCard entry={entry} index={featuredProjects.length + index} />)}
          </div>
        </div>
      )}

      <div class="mt-10">
        <LinkButton href="/" variant="secondary">Back to home</LinkButton>
      </div>
    </Container>
  </section>
</BaseLayout>
