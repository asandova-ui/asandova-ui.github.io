---
import { ArrowRight } from "@lucide/astro";
import { isExternalLink, withBase } from "@/lib/utils";

interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  external?: boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  external = false,
  ariaLabel,
  class: className = ""
} = Astro.props;

const resolvedHref = !external && !isExternalLink(href) ? withBase(href) : href;

const variantClasses = {
  primary:
    "border-transparent bg-[color:var(--color-fg)] text-[color:var(--color-bg)] hover:-translate-y-0.5 hover:bg-[color:var(--color-accent-strong)]",
  secondary:
    "border-[color:var(--color-border)] bg-white/70 text-[color:var(--color-fg)] hover:-translate-y-0.5 hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]",
  ghost:
    "border-transparent bg-transparent text-[color:var(--color-fg)] hover:text-[color:var(--color-accent-strong)]"
};
---

<a
  href={resolvedHref}
  aria-label={ariaLabel}
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
  class:list={[
    "inline-flex items-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold tracking-[0.01em]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-bg)]",
    variantClasses[variant],
    className
  ]}
>
  <slot />
  <ArrowRight class="size-4" aria-hidden="true" />
</a>
