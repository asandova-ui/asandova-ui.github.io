---
import { MapPin } from "@lucide/astro";
import Container from "@/components/Container.astro";
import LinkButton from "@/components/LinkButton.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { siteConfig } from "@/lib/site";
---

<section class="relative pt-4 pb-10 sm:pt-6 sm:pb-16">
  <Container class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
    <div class="space-y-7">
      <div class="space-y-4">
        <a
          href={siteConfig.venture.href}
          target="_blank"
          rel="noreferrer"
          class="inline-flex flex-wrap items-center gap-x-2 gap-y-1 rounded-full border border-[color:var(--color-accent)]/25 bg-[color:var(--color-accent)]/10 px-4 py-2 text-[0.72rem] font-semibold tracking-[0.14em] uppercase text-[color:var(--color-accent-strong)]"
        >
          <span>{siteConfig.role}</span>
          <span aria-hidden="true" class="text-[color:var(--color-accent)]/70">|</span>
          <span>{siteConfig.venture.role} at {siteConfig.venture.name}</span>
        </a>
        <h1 class="max-w-3xl text-4xl leading-[1.02] font-semibold tracking-[-0.05em] text-balance sm:text-[3.35rem] lg:text-[3.9rem]">
          {siteConfig.headline}
        </h1>
        <p class="max-w-2xl text-base leading-8 text-[color:var(--color-muted)] sm:text-lg">
          {siteConfig.intro}
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <LinkButton href="/#projects">View Projects</LinkButton>
        <LinkButton href="/#contact" variant="secondary">Contact</LinkButton>
      </div>

      <div class="space-y-4 border-t pt-5">
        <div class="flex items-center gap-2 text-sm">
          <MapPin class="size-4 text-[color:var(--color-accent-strong)]" aria-hidden="true" />
          <span class="text-[color:var(--color-muted)]">{siteConfig.location}</span>
        </div>
        <SocialLinks links={siteConfig.socialLinks} />
      </div>
    </div>

    <aside class="border-t pt-6 lg:border-t-0 lg:border-l lg:pt-2 lg:pl-6">
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-muted)]">
          Current
        </p>
        <div class="space-y-1">
          <p class="font-heading text-xl leading-tight font-semibold text-[color:var(--color-fg)]">
            {siteConfig.venture.name}
          </p>
          <p class="text-sm text-[color:var(--color-muted)]">{siteConfig.venture.category}</p>
        </div>
        <p class="text-sm leading-7">
          {siteConfig.venture.summary}
        </p>
        <div class="space-y-3 border-t pt-4 text-sm">
          <div>
            <p class="font-heading font-semibold text-[color:var(--color-fg)]">Scope</p>
            <p class="mt-1 leading-7">{siteConfig.venture.scope}</p>
          </div>
        </div>
        <a
          href={siteConfig.venture.href}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center text-sm font-medium text-[color:var(--color-accent-strong)] hover:text-[color:var(--color-fg)]"
        >
          Visit website
        </a>
      </div>
    </aside>
  </Container>
</section>
