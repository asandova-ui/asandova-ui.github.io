---
import { MapPin } from "@lucide/astro";
import Container from "@/components/Container.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { siteConfig } from "@/lib/site";
---

<section class="relative pt-12 pb-14 sm:pt-16 sm:pb-18">
  <Container>
    <div class="grid max-w-5xl gap-10 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
      <div class="max-w-3xl space-y-5">
        <p class="font-heading text-[0.76rem] font-semibold uppercase tracking-[0.08em] text-[color:var(--color-accent-strong)]">
          {siteConfig.venture.role} at
          <a
            href={siteConfig.venture.href}
            target="_blank"
            rel="noreferrer"
            class="hover:text-[color:var(--color-fg)]"
          >
            {siteConfig.venture.name}
          </a>
        </p>
        <p class="text-[1.25rem] leading-[1.6] text-[color:var(--color-fg)] sm:text-[1.45rem]">
          {siteConfig.headline}
        </p>
        <p class="max-w-2xl text-[1rem] leading-7 text-[color:var(--color-muted)] sm:text-[1.04rem]">
          {siteConfig.intro}
        </p>
      </div>

      <aside class="space-y-4 text-[0.94rem] leading-6 text-[color:var(--color-muted)]">
        <p>
          Currently building
          <a
            href={siteConfig.venture.href}
            target="_blank"
            rel="noreferrer"
            class="font-medium text-[color:var(--color-fg)] hover:text-[color:var(--color-accent-strong)]"
          >
            {siteConfig.venture.name}
          </a>
          and exploring AI products, data infrastructure, and early-stage company building.
        </p>
        <div class="flex items-center gap-2 text-[0.92rem]">
          <MapPin class="size-4 text-[color:var(--color-accent-strong)]" aria-hidden="true" />
          <span class="text-[color:var(--color-muted)]">{siteConfig.location}</span>
        </div>
        <SocialLinks links={siteConfig.socialLinks} />
      </aside>
    </div>
  </Container>
</section>
