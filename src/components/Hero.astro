---
import { MapPin } from "@lucide/astro";
import Container from "@/components/Container.astro";
import LinkButton from "@/components/LinkButton.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { siteConfig } from "@/lib/site";
---

<section class="relative pt-16 pb-10 sm:pt-24 sm:pb-16">
  <Container class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(22rem,0.8fr)] lg:items-end">
    <div class="space-y-8">
      <div class="space-y-5">
        <span class="eyebrow">Portfolio / Engineering / Systems</span>
        <div class="space-y-4">
          <p class="text-sm font-semibold tracking-[0.18em] uppercase text-[color:var(--color-accent-strong)]">
            {siteConfig.role}
          </p>
          <h1 class="max-w-4xl text-5xl leading-[0.95] font-semibold sm:text-6xl lg:text-7xl">
            {siteConfig.headline}
          </h1>
          <p class="section-copy text-balance">{siteConfig.intro}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <LinkButton href="/#projects">View Projects</LinkButton>
        <LinkButton href="/#contact" variant="secondary">Contact</LinkButton>
      </div>

      <div class="space-y-4 border-t pt-6">
        <div class="flex items-center gap-2 text-sm">
          <MapPin class="size-4 text-[color:var(--color-accent-strong)]" aria-hidden="true" />
          <span class="text-[color:var(--color-muted)]">{siteConfig.location}</span>
        </div>
        <SocialLinks links={siteConfig.socialLinks} />
      </div>
    </div>

    <aside class="surface-card relative overflow-hidden p-7 sm:p-8">
      <div
        aria-hidden="true"
        class="absolute inset-x-0 top-0 h-36 bg-[radial-gradient(circle_at_top,rgba(217,119,87,0.18),transparent_70%)]"
      ></div>
      <div class="relative space-y-8">
        <div class="space-y-3">
          <p class="text-sm font-semibold tracking-[0.16em] uppercase text-[color:var(--color-muted)]">
            Current focus
          </p>
          <ul class="space-y-4">
            {
              siteConfig.currentFocus.map((item) => (
                <li class="border-l-2 border-[color:var(--color-accent)]/45 pl-4 text-base leading-7">
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="grid gap-4 border-t pt-6 text-sm sm:grid-cols-2">
          <div>
            <p class="font-heading font-semibold text-[color:var(--color-fg)]">Positioning</p>
            <p class="mt-2 leading-7">Deep technical credibility with product and delivery range.</p>
          </div>
          <div>
            <p class="font-heading font-semibold text-[color:var(--color-fg)]">Availability</p>
            <p class="mt-2 leading-7">{siteConfig.availability}</p>
          </div>
        </div>
      </div>
    </aside>
  </Container>
</section>
