---
import { MapPin } from "@lucide/astro";
import Container from "@/components/Container.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { siteConfig } from "@/lib/site";
---

<section class="relative pt-4 pb-8 sm:pt-5 sm:pb-12">
  <Container>
    <div class="max-w-4xl space-y-7">
      <div class="space-y-5">
        <a
          href={siteConfig.venture.href}
          target="_blank"
          rel="noreferrer"
          class="inline-flex flex-wrap items-center gap-x-2 gap-y-1 rounded-full border border-[color:var(--color-accent)]/25 bg-[color:var(--color-accent)]/10 px-4 py-2 text-[0.72rem] font-semibold tracking-[0.14em] uppercase text-[color:var(--color-accent-strong)]"
        >
          <span>{siteConfig.role}</span>
          <span aria-hidden="true" class="text-[color:var(--color-accent)]/70">|</span>
          <span>{siteConfig.venture.role} at {siteConfig.venture.name}</span>
        </a>
        <h1 class="max-w-4xl text-lg leading-8 font-medium text-balance text-[color:var(--color-fg)] sm:text-[1.15rem]">
          {siteConfig.headline}
        </h1>
        <p class="max-w-4xl text-lg leading-8 text-[color:var(--color-muted)] sm:text-[1.15rem]">
          {siteConfig.intro}
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[color:var(--color-muted)]">
        <span>
          Currently building
          <a
            href={siteConfig.venture.href}
            target="_blank"
            rel="noreferrer"
            class="font-medium text-[color:var(--color-fg)] hover:text-[color:var(--color-accent-strong)]"
          >
            {siteConfig.venture.name}
          </a>
        </span>
        <span aria-hidden="true" class="hidden text-[color:var(--color-border)] sm:inline">/</span>
        <span>Particularly interested in AI products, data infrastructure, and startup environments.</span>
      </div>

      <div class="space-y-4 border-t pt-5">
        <div class="flex items-center gap-2 text-sm">
          <MapPin class="size-4 text-[color:var(--color-accent-strong)]" aria-hidden="true" />
          <span class="text-[color:var(--color-muted)]">{siteConfig.location}</span>
        </div>
        <SocialLinks links={siteConfig.socialLinks} />
      </div>
    </div>
  </Container>
</section>
