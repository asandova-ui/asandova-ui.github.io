---
import type { SkillGroupData } from "@/lib/site";

interface Props {
  group: SkillGroupData;
}

const { group } = Astro.props;
---

<article class="surface-card h-full p-6 sm:p-7">
  <div class="space-y-5">
    <div class="space-y-2">
      <h3 class="text-xl font-semibold">{group.title}</h3>
      <p class="text-sm leading-7">{group.description}</p>
    </div>
    <ul class="flex flex-wrap gap-2">
      {
        group.items.map((item) => (
          <li class="chip">{item}</li>
        ))
      }
    </ul>
  </div>
</article>
