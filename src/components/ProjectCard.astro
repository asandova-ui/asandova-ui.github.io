---
import { ExternalLink } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";
import { withBase } from "@/lib/utils";

interface Props {
  entry: CollectionEntry<"projects">;
  featured?: boolean;
  index?: number;
}

const { entry, index } = Astro.props;
const { data, id } = entry;
const cardCopy = data.description;
const displayIndex = typeof index === "number" ? String(index + 1).padStart(2, "0") : undefined;
const statusToneClasses =
  data.cardStatusTone === "live"
    ? "text-emerald-700"
    : data.cardStatusTone === "building"
      ? "text-[color:var(--color-accent-strong)]"
      : "text-[color:var(--color-muted)]";
const statusDotClasses =
  data.cardStatusTone === "live"
    ? "bg-emerald-500"
    : data.cardStatusTone === "building"
      ? "bg-[color:var(--color-accent)]"
      : "bg-[color:var(--color-muted)]/55";
---

<article
  class:list={[
    "group border-b editorial-rule py-6 transition-colors sm:py-7",
    "hover:bg-[rgba(255,252,245,0.28)]"
  ]}
>
  <div class="grid gap-4 sm:grid-cols-[2.8rem_minmax(0,1fr)] lg:grid-cols-[2.8rem_minmax(0,1fr)_auto] lg:items-start lg:gap-8">
    {displayIndex && (
      <span class="font-heading text-[0.78rem] text-[color:var(--color-soft)] sm:pt-1">{displayIndex}</span>
    )}

    <div class="max-w-3xl">
      <h3 class="text-[1.22rem] leading-tight font-semibold sm:text-[1.42rem]">
        <a href={withBase(`/projects/${id}/`)} class="hover:text-[color:var(--color-accent-strong)]">
          {data.title}
        </a>
      </h3>
      <p class="mt-2.5 max-w-2xl text-[0.95rem] leading-7 text-[color:var(--color-muted)]">{cardCopy}</p>
    </div>

    <div class="flex flex-wrap items-center gap-3 sm:col-start-2 lg:col-start-auto lg:justify-end">
      <div class="flex items-center gap-3 lg:text-right">
          {data.cardStatusLabel && (
            <span class:list={[
              "inline-flex items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.08em]",
              statusToneClasses
            ]}>
              <span aria-hidden="true" class:list={["size-1.5 rounded-full", statusDotClasses]}></span>
              {data.cardStatusLabel}
            </span>
          )}
          <span class="text-[0.82rem] text-[color:var(--color-muted)]">{data.year}</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 pt-1 text-[0.9rem] font-medium text-[color:var(--color-fg)] sm:col-start-2 lg:col-span-2">
      <a
        href={withBase(`/projects/${id}/`)}
        class="inline-flex items-center gap-2 hover:text-[color:var(--color-accent-strong)]"
      >
        Read case study
        <span aria-hidden="true">→</span>
      </a>
      {
        data.links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 text-[color:var(--color-muted)] hover:text-[color:var(--color-accent-strong)]"
          >
            {link.label}
            <ExternalLink class="size-3.5" aria-hidden="true" />
          </a>
        ))
      }
    </div>
  </div>
</article>
