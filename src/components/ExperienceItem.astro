---
import type { ExperienceItemData } from "@/lib/site";

interface Props {
  item: ExperienceItemData;
}

const { item } = Astro.props;
---

<article class="relative pl-8">
  <span
    aria-hidden="true"
    class="absolute left-0 top-2.5 size-3 rounded-full border-4 border-[color:var(--color-bg)] bg-[color:var(--color-accent)]"
  ></span>
  <div class="surface-card p-6 sm:p-7">
    <div class="flex flex-col gap-3 border-b pb-5 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-semibold tracking-[0.18em] uppercase text-[color:var(--color-accent-strong)]">
          {item.company}
        </p>
        <h3 class="mt-2 text-2xl leading-tight font-semibold">{item.role}</h3>
      </div>
      <p class="text-sm font-medium text-[color:var(--color-muted)]">{item.period}</p>
    </div>

    <div class="mt-5 space-y-5">
      <p class="text-base leading-8">{item.summary}</p>
      <ul class="space-y-3">
        {
          item.bullets.map((bullet) => (
            <li class="flex gap-3 text-sm leading-7 sm:text-base">
              <span aria-hidden="true" class="mt-3 size-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
              <span>{bullet}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</article>
