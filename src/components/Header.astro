---
import Container from "@/components/Container.astro";
import { siteConfig } from "@/lib/site";
import { withBase } from "@/lib/utils";
---

<header class="relative z-20 pt-6 sm:pt-8">
  <Container class="flex items-center justify-between gap-6 py-2">
    <a href={withBase("/")} class="flex items-center gap-3.5 text-[color:var(--color-fg)]">
      <img
        src={withBase(siteConfig.profileImage)}
        alt={`Portrait of ${siteConfig.name}`}
        class="size-[3.45rem] rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] object-cover object-[center_72%] shadow-[0_10px_24px_rgba(63,44,28,0.08)] sm:size-[4rem]"
        loading="eager"
        decoding="async"
      />
      <div>
        <span class="block font-heading text-[1rem] font-semibold uppercase tracking-[0.08em] sm:text-[1.06rem]">{siteConfig.name}</span>
      </div>
    </a>
    <nav aria-label="Primary" class="overflow-x-auto">
      <ul class="flex items-center gap-1 text-[0.92rem] sm:gap-2">
        {
          siteConfig.navigation.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                class="inline-flex px-2.5 py-2 text-[color:var(--color-muted)] hover:text-[color:var(--color-accent-strong)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>
</header>
