---
import { Briefcase, Code, FileText, Mail } from "@lucide/astro";
import type { SocialLink } from "@/lib/site";
import { isExternalLink, withBase } from "@/lib/utils";

interface Props {
  links: readonly SocialLink[] | SocialLink[];
  compact?: boolean;
}

const { links, compact = false } = Astro.props;

const iconMap = {
  github: Code,
  linkedin: Briefcase,
  "file-text": FileText,
  mail: Mail
} as const;
---

<ul class:list={["flex flex-wrap items-center gap-x-5 gap-y-2", compact && "gap-x-4"]}>
  {
    links.map((link) => {
      const Icon = iconMap[link.icon];

      return (
        <li>
          <a
            href={isExternalLink(link.href) ? link.href : withBase(link.href)}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
            class:list={[
              "inline-flex items-center gap-2 border-b border-transparent pb-1 text-[color:var(--color-fg)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]",
              compact ? "text-[0.86rem]" : "text-[0.92rem]"
            ]}
            aria-label={link.label}
          >
            <Icon class="size-4" aria-hidden="true" />
            <span>{link.label}</span>
          </a>
        </li>
      );
    })
  }
</ul>
