---
interface Props {
  eyebrow: string;
  title?: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-7 sm:mb-9">
  {title ? (
    <div class="max-w-3xl space-y-3">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="max-w-3xl text-[1.45rem] leading-tight font-semibold sm:text-[1.72rem]">{title}</h2>
      {description && <p class="max-w-2xl text-[0.98rem] leading-7 text-[color:var(--color-muted)] sm:text-[1.03rem]">{description}</p>}
    </div>
  ) : (
    <div class="flex items-end justify-between gap-4">
      <h2 class="font-heading text-[1.45rem] leading-tight font-semibold text-[color:var(--color-fg)] sm:text-[1.72rem]">
        {eyebrow}
      </h2>
      {description && <p class="max-w-xl text-sm leading-6 sm:text-[0.96rem]">{description}</p>}
    </div>
  )}
</div>
