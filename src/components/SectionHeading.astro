---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-10 space-y-4 sm:mb-12">
  <span class="eyebrow">{eyebrow}</span>
  <div class="max-w-3xl space-y-3">
    <h2 class="max-w-3xl text-3xl leading-tight font-semibold sm:text-4xl">{title}</h2>
    {description && <p class="section-copy">{description}</p>}
  </div>
</div>
